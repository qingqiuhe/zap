---
// 主题切换按钮 — Sun / Moon / System 三段切换
// 实际逻辑由 LandingLayout / DocsLayout 的 inline script 接管(避免 FOUC)
---
<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  aria-label="Toggle color theme"
  title="Toggle theme"
>
  <svg class="ico-sun" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <circle cx="8" cy="8" r="3"/>
    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.2 3.2l1.4 1.4M11.4 11.4l1.4 1.4M3.2 12.8l1.4-1.4M11.4 4.6l1.4-1.4"/>
  </svg>
  <svg class="ico-moon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M14 9.5A6 6 0 1 1 6.5 2a5 5 0 0 0 7.5 7.5z"/>
  </svg>
</button>
