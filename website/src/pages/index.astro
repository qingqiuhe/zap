  <!-- 终端打字行(只渲染一次,LandingLayout 的 IntersectionObserver 触发 .in 后 typing-fade 启动) -->
  <!-- 实际的 typing 内容已经在 mock-terminal 的 .term-stage 内填充 -->
</LandingLayout>

<script>
  // ============================================================
  // Hero 仿真终端:可执行的 fake shell
  // - 预设几个命令(help / ls / pwd / clear / agent / provider / theme / whoami / echo)
  // - 响应按当前 locale 切换三语
  // - 上/下箭头可走历史
  // ============================================================
  (function () {
    const stage = document.querySelector('.hero-art .term-stage') as HTMLElement | null;
    if (!stage) return;

    // 初始动画行(页面刚加载时)
    const initLines = [
      `<span class="p">$</span> npm run build`,
      `<span class="dim">› vite v5.4 · production</span>`,
      `<span class="dim">› 248 modules transformed</span>`,
      `<span class="ok">✓ built in 1.24s</span>`,
    ];
    stage.innerHTML = initLines.map((l) => `<div class="typing-line">${l}</div>`).join('');

    const inputs = Array.from(document.querySelectorAll<HTMLInputElement>('.ti-fakeshell input'));
    if (!inputs.length) return;
    const history: string[] = [];
    let histIdx = -1;

    function locale(): 'en' | 'zh' | 'ja' {
      const l = document.body.dataset.locale || document.documentElement.getAttribute('data-locale') || 'en';
      if (l === 'zh' || l === 'ja') return l;
      return 'en';
    }
    function pickInput(): HTMLInputElement | null {
      const lc = locale();
      return inputs.find((el) => el.dataset.lang === lc) || inputs[0] || null;
    }
    function escape(s: string) {
      return s.replace(/&/g, '&amp;').replace(/[<]/g, '&lt;').replace(/[>]/g, '&gt;');
    }
    function printRaw(html: string, cls = '') {
      const div = document.createElement('div');
      div.className = 'out-line' + (cls ? ' ' + cls : '');
      div.innerHTML = html;
      stage.appendChild(div);
      stage.scrollTop = stage.scrollHeight;
    }
    function printLines(lines: string[], cls = '') {
      lines.forEach((l, i) => {
        setTimeout(() => printRaw(l, cls), i * 60);
      });
    }

    // 多语响应表
    const responses: Record<string, Record<'en' | 'zh' | 'ja', string[]>> = {
      help: {
        en: [
          'Available commands:',
          '  help               show this list',
          '  ls                 list current directory',
          '  pwd                print working directory',
          '  whoami             print current user',
          '  echo &lt;text&gt;        print text back',
          '  agent &lt;prompt&gt;     send a prompt to the local AI agent',
          '  provider list      list configured AI providers',
          '  theme              toggle dark / light',
          '  clear              clear the screen',
        ],
        zh: [
          '可用命令:',
          '  help               显示本列表',
          '  ls                 列出当前目录',
          '  pwd                输出当前路径',
          '  whoami             输出当前用户',
          '  echo &lt;文本&gt;        原样输出文本',
          '  agent &lt;prompt&gt;     向本地 AI 代理发送提示',
          '  provider list      列出已配置的服务商',
          '  theme              切换深/浅色主题',
          '  clear              清屏',
        ],
        ja: [
          '利用可能なコマンド:',
          '  help               この一覧を表示',
          '  ls                 カレントディレクトリ表示',
          '  pwd                現在のパスを表示',
          '  whoami             現在のユーザーを表示',
          '  echo &lt;テキスト&gt;    テキストをそのまま出力',
          '  agent &lt;prompt&gt;     ローカル AI エージェントに送信',
          '  provider list      設定済みプロバイダー一覧',
          '  theme              ダーク / ライトを切り替え',
          '  clear              画面をクリア',
        ],
      },
      ls: {
        en: ['Cargo.toml  CHANGELOG.md  README.md  app/  crates/  docs/  scripts/  website/'],
        zh: ['Cargo.toml  CHANGELOG.md  README.md  app/  crates/  docs/  scripts/  website/'],
        ja: ['Cargo.toml  CHANGELOG.md  README.md  app/  crates/  docs/  scripts/  website/'],
      },
      pwd: { en: ['/home/you/zap'], zh: ['/home/you/zap'], ja: ['/home/you/zap'] },
      whoami: { en: ['you'], zh: ['you'], ja: ['you'] },
      providerList: {
        en: [
          '<span class="k">PROTOCOL</span>           <span class="k">NAME</span>          <span class="k">STATUS</span>',
          'openai            anthropic     <span class="s">ready</span>',
          'anthropic         claude-4-7    <span class="s">ready</span>',
          'deepseek          deepseek-v4   <span class="s">ready</span>',
          'ollama            local         <span class="s">ready</span>',
        ],
        zh: [
          '<span class="k">协议</span>             <span class="k">名称</span>          <span class="k">状态</span>',
          'openai            anthropic     <span class="s">就绪</span>',
          'anthropic         claude-4-7    <span class="s">就绪</span>',
          'deepseek          deepseek-v4   <span class="s">就绪</span>',
          'ollama            local         <span class="s">就绪</span>',
        ],
        ja: [
          '<span class="k">プロトコル</span>         <span class="k">名前</span>          <span class="k">状態</span>',
          'openai            anthropic     <span class="s">ready</span>',
          'anthropic         claude-4-7    <span class="s">ready</span>',
          'deepseek          deepseek-v4   <span class="s">ready</span>',
          'ollama            local         <span class="s">ready</span>',
        ],
      },
    };

    function agentResponse(prompt: string): string[] {
      const lc = locale();
      const cleaned = prompt.trim() || (lc === 'zh' ? '没有输入提示' : lc === 'ja' ? 'プロンプトがありません' : 'no prompt');
      if (lc === 'zh') {
        return [
          `<span class="k">[agent]</span> <span class="dim">路由至</span> anthropic/claude-4-7`,
          `<span class="k">[agent]</span> <span class="dim">prompt</span>: ${escape(cleaned)}`,
          `<span class="dim">思考中...</span>`,
          `<span class="s">→</span> 这是一个仿真响应。实际使用时会在本地调用你配置的服务商。`,
          `<span class="dim">凭证、会话、上下文全部在本地。</span>`,
        ];
      }
      if (lc === 'ja') {
        return [
          `<span class="k">[agent]</span> <span class="dim">ルーティング:</span> anthropic/claude-4-7`,
          `<span class="k">[agent]</span> <span class="dim">prompt</span>: ${escape(cleaned)}`,
          `<span class="dim">考え中...</span>`,
          `<span class="s">→</span> これはシミュレーションです。実際にはローカルで設定済みプロバイダーを呼び出します。`,
          `<span class="dim">認証、会話、コンテキストはすべてローカルに残ります。</span>`,
        ];
      }
      return [
        `<span class="k">[agent]</span> <span class="dim">routing to</span> anthropic/claude-4-7`,
        `<span class="k">[agent]</span> <span class="dim">prompt</span>: ${escape(cleaned)}`,
        `<span class="dim">thinking...</span>`,
        `<span class="s">→</span> This is a simulated response. In real Zap this would call your configured provider locally.`,
        `<span class="dim">Credentials, conversation and context all stay on your machine.</span>`,
      ];
    }

    function run(raw: string) {
      const cmd = raw.trim();
      if (!cmd) return;
      history.push(cmd);
      histIdx = history.length;

      // 回显命令
      printRaw(`<span class="p">$</span> ${escape(cmd)}`);

      const lc = locale();
      const lower = cmd.toLowerCase();
      const head = cmd.split(/\s+/)[0].toLowerCase();
      const rest = cmd.slice(head.length).trim();

      if (lower === 'clear' || lower === 'cls') {
        setTimeout(() => { stage.innerHTML = ''; }, 80);
        return;
      }
      if (head === 'help') { printLines(responses.help[lc], 'dim'); return; }
      if (head === 'ls')   { printLines(responses.ls[lc]); return; }
      if (head === 'pwd')  { printLines(responses.pwd[lc]); return; }
      if (head === 'whoami') { printLines(responses.whoami[lc]); return; }
      if (head === 'echo') { printRaw(escape(rest)); return; }
      if (head === 'theme') {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('zap:theme', next); } catch (_) {}
        const msg = lc === 'zh' ? `已切换至 ${next} 主题` : lc === 'ja' ? `テーマを ${next} に切り替えました` : `Theme switched to ${next}`;
        printRaw(msg, 'ok');
        return;
      }
      if (head === 'provider' && rest === 'list') {
        printLines(responses.providerList[lc]);
        return;
      }
      if (head === 'agent') { printLines(agentResponse(rest)); return; }

      // 未知命令
      const errMsg = lc === 'zh'
        ? `zap: 未知命令: ${escape(head)}。输入 <span class="s">help</span> 查看可用命令。`
        : lc === 'ja'
        ? `zap: コマンドが見つかりません: ${escape(head)}。<span class="s">help</span> で一覧。`
        : `zap: command not found: ${escape(head)}. Type <span class="s">help</span> to list commands.`;
      printRaw(errMsg, 'err');
    }

    inputs.forEach((input) => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const val = input.value;
          input.value = '';
          run(val);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (history.length === 0) return;
          histIdx = Math.max(0, histIdx - 1);
          input.value = history[histIdx] || '';
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (histIdx < history.length - 1) {
            histIdx += 1;
            input.value = history[histIdx] || '';
          } else {
            histIdx = history.length;
            input.value = '';
          }
        }
      });
    });

    // 仿真窗口里的"语言"下拉 — 点击后同步全站 locale,对齐 nav 里的语言菜单。
    // 这里重用 LandingLayout 中已有的 setLocale 逻辑:直接写 localStorage + body.dataset.locale +
    // applyLocale 生效。为避免重写,使用同一 storage key 与同一套选择器。
    function setLocaleAcrossSite(lc) {
      const supported = ['en', 'zh', 'ja'];
      let actual = lc;
      if (lc === 'system') {
        const nav = (navigator.language || 'en').toLowerCase();
        actual = nav.startsWith('zh') ? 'zh' : nav.startsWith('ja') ? 'ja' : 'en';
      }
      if (!supported.includes(actual)) actual = 'en';
      // 1. body.dataset.locale 控制 [data-lang] 的可见性
      document.body.dataset.locale = actual;
      // 2. <html> lang 属性
      document.documentElement.lang = actual === 'zh' ? 'zh-CN' : actual;
      // 3. <html> data-locale(供 CSS 其他场景使用)
      document.documentElement.setAttribute('data-locale', actual);
      // 4. 持久化 — 所以下一次打开也记住
      try { localStorage.setItem('zap:locale', actual); } catch (_) {}
      // 5. 同步更新 nav lang 下拉中的 active 状态
      document.querySelectorAll('[data-set-lang]').forEach((opt) => {
        const active = opt.getAttribute('data-set-lang') === actual;
        opt.classList.toggle('active', active);
        opt.setAttribute('aria-selected', String(active));
      });
      // 6. 同步 mock dropdown 里的 active(高亮当前选项)
      document.querySelectorAll('[data-mock-lang]').forEach((opt) => {
        const v = opt.getAttribute('data-mock-lang');
        opt.classList.toggle('active', v === actual || (v === 'system' && !localStorage.getItem('zap:locale')));
      });
    }
    document.querySelectorAll('[data-mock-lang]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const target = btn.getAttribute('data-mock-lang') || 'en';
        setLocaleAcrossSite(target);
      });
    });
    // 页面载入后同步一次初始高亮
    document.querySelectorAll('[data-mock-lang]').forEach((opt) => {
      const v = opt.getAttribute('data-mock-lang');
      const cur = document.body.dataset.locale || 'en';
      opt.classList.toggle('active', v === cur);
    });
  })();
</script>
