---
import LandingLayout from '../layouts/LandingLayout.astro';

const repo = 'https://github.com/zerx-lab/zap';

// 文案集中管理,避免三语 data-lang 标签散落各处
const t = {
  hero: {
    badge:  { en: 'v0 · OSS preview',     zh: 'v0 · OSS 预览版',     ja: 'v0 · OSS プレビュー' },
    h1a:    { en: 'The terminal,',         zh: '把终端,',              ja: 'ターミナルを、' },
    h1b:    { en: 'rebuilt around you.',   zh: '重新交还给你。',         ja: 'あなたの手元に戻す。' },
    lede:   {
      en: 'Zap is a derivative product built on Warp — a fully open, local-first take on the agentic terminal. Every credential, conversation and key stays on your machine. Bring your own provider, your own keys, your own rules.',
      zh: 'Zap 是基于 Warp 的衍生产品 — 完全开放、本地优先的 agentic 终端。凭证、会话与密钥全部保存在本地。自带服务商、自带密钥、自带规则。',
      ja: 'Zap は Warp を基にした派生プロダクト — 完全オープンでローカルファーストな agentic ターミナル。認証情報、会話、鍵はすべて手元のマシンに残ります。プロバイダーも鍵もルールも自分のもの。',
    },
    primary:   { en: 'Install Zap',     zh: '安装 Zap',     ja: 'Zap をインストール' },
    secondary: { en: 'View on GitHub',  zh: '在 GitHub 查看', ja: 'GitHub で見る' },
  },
  logos: {
    title: {
      en: 'Native protocols — bring any provider',
      zh: '原生协议 — 自带任意服务商',
      ja: 'ネイティブプロトコル — 任意のプロバイダーを接続',
    },
  },
  feat1: {
    eyebrow: { en: 'TERMINAL',    zh: '终端',          ja: 'ターミナル' },
    h:       { en: 'A real terminal, with an AI you actually own.',  zh: '一个真正的终端,搭配你自己掌控的 AI。',  ja: '本物のターミナル、自分で制御できる AI 付き。' },
    p:       {
      en: 'Every Block — cwd, env, exit code — feeds an AI conversation you can swap, replay or kill at any time. No telemetry, no remote calls, no hidden cloud.',
      zh: '每一个 Block(工作目录、环境变量、退出码)都为 AI 会话提供上下文,而对话本身可以随时替换、重放、终止。无遥测、无远程调用、无隐藏云服务。',
      ja: 'すべての Block(cwd、env、終了コード)が AI 会話に流れ込み、いつでも切り替え・再実行・停止できます。テレメトリも遠隔呼び出しも隠れたクラウドもありません。',
    },
    more: { en: 'Read the docs →', zh: '查看文档 →', ja: 'ドキュメントを見る →' },
  },
  feat2: {
    eyebrow: { en: 'PROVIDERS',   zh: '服务商',        ja: 'プロバイダー' },
    h:       { en: 'Six native protocols. Hundreds of presets. Your keys.', zh: '6 种原生协议,数百个预设,你的密钥。', ja: '6 種のネイティブプロトコル、数百のプリセット、あなたの鍵。' },
    p:       {
      en: 'Pick from a directory of 250+ providers — OpenAI-compatible, Anthropic, Gemini, Ollama, DeepSeek, OpenAI-Response — or wire your own endpoint in one paste. Keys live in the OS keychain.',
      zh: '从内置 250+ 服务商目录中挑选 — OpenAI 兼容、Anthropic、Gemini、Ollama、DeepSeek、OpenAI-Response — 也可一键粘贴你自己的端点。密钥仅保存在系统密钥库。',
      ja: '内蔵の 250+ プロバイダーディレクトリから選択(OpenAI 互換、Anthropic、Gemini、Ollama、DeepSeek、OpenAI-Response)。あるいは自分のエンドポイントを 1 度の貼り付けで接続。鍵は OS のキーチェーンに保管されます。',
    },
    more: { en: 'See provider list →', zh: '查看服务商列表 →', ja: 'プロバイダー一覧を見る →' },
  },
  feat3: {
    eyebrow: { en: 'LOCALIZED',   zh: '本地化',        ja: 'ローカライズ' },
    h:       { en: 'Localized end-to-end. Not just labels.',  zh: '端到端本地化,不只是标签翻译。', ja: '端から端までローカライズ。ラベルだけではありません。' },
    p:       {
      en: 'Settings, prompts, command palette, telemetry banners — all rewritten in English, 简体中文 and 日本語. Switch any time; preference persists locally.',
      zh: '设置、Prompt、命令面板、隐私横幅 — 全部用 English / 简体中文 / 日本語 重写。可随时切换,偏好仅保存在本地。',
      ja: '設定、プロンプト、コマンドパレット、テレメトリバナー — すべて English / 简体中文 / 日本語 で書き直されています。いつでも切替可能、設定はローカルに保存。',
    },
    more: { en: 'Switch language ↑', zh: '切换语言 ↑', ja: '言語を切り替える ↑' },
  },
  quote: {
    text: {
      en: 'The terminal was always a local tool. Zap keeps it that way — even when the AI joins.',
      zh: '终端从来都是本地工具。即便引入 AI,Zap 也让它继续如此。',
      ja: 'ターミナルはずっとローカルなツールでした。AI が入っても、Zap はそのままにします。',
    },
    cite: { en: 'Project ethos', zh: '项目理念', ja: 'プロジェクトの理念' },
  },
  install: {
    eyebrow: { en: 'INSTALL',    zh: '安装',           ja: 'インストール' },
    h:       { en: 'Build it yourself in two commands.', zh: '两条命令,自行构建。',          ja: '2 つのコマンドで自分でビルド。' },
    p:       {
      en: 'No installer in preview — Zap is source-available and ships only as a build script. Clone, bootstrap, run.',
      zh: 'preview 阶段不提供安装包 — Zap 完全源码公开,只通过构建脚本发布。Clone、bootstrap、run。',
      ja: 'preview 段階ではインストーラーはありません。Zap はソース公開で、ビルドスクリプトのみが配布物です。Clone、bootstrap、run。',
    },
    tabMac: 'macOS', tabLinux: 'Linux', tabWin: 'Windows',
  },
  cta: {
    h:       { en: 'Your terminal. Your keys.',  zh: '你的终端。你的密钥。', ja: 'あなたのターミナル。あなたの鍵。' },
    p:       { en: 'Source-available · Self-hostable · Built with Rust', zh: '源码公开 · 可自托管 · 基于 Rust 构建', ja: 'ソース公開 · セルフホスト可能 · Rust 製' },
    primary: { en: 'Quickstart',  zh: '快速开始',  ja: 'クイックスタート' },
    secondary: { en: 'Read the changelog', zh: '查看更新日志', ja: '変更履歴を読む' },
  },
};

// 提供商示例(对应仿真 2 的 chip-grid)
const providerChips = ['302.AI (97)', 'Abacus (65)', 'abliteration.ai (1)', 'AIHubMix (50)', 'Alibaba (48)', 'Alibaba (China) (80)', 'Alibaba Coding (9)', 'Together (16)'];

// Logos(信赖墙)— 我们没有真实合作伙伴,改成"原生支持的协议名"
const protocols = ['OpenAI', 'Anthropic', 'Gemini', 'Ollama', 'DeepSeek', 'OpenAI-Response'];
---
<LandingLayout>
  <!-- ============== HERO ============== -->
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="fade-in">
        <span class="hero-badge"><span class="pulse-dot"></span>
          <span data-lang="en">{t.hero.badge.en}</span><span data-lang="zh">{t.hero.badge.zh}</span><span data-lang="ja">{t.hero.badge.ja}</span>
        </span>
        <h1>
          <span data-lang="en">{t.hero.h1a.en}<br/><span class="em">{t.hero.h1b.en}</span></span>
          <span data-lang="zh">{t.hero.h1a.zh}<br/><span class="em">{t.hero.h1b.zh}</span></span>
          <span data-lang="ja">{t.hero.h1a.ja}<br/><span class="em">{t.hero.h1b.ja}</span></span>
        </h1>
        <p class="lede" data-lang="en">{t.hero.lede.en}</p>
        <p class="lede" data-lang="zh">{t.hero.lede.zh}</p>
        <p class="lede" data-lang="ja">{t.hero.lede.ja}</p>
        <div class="hero-cta">
          <a class="btn" href="#install">
            <span data-lang="en">{t.hero.primary.en}</span><span data-lang="zh">{t.hero.primary.zh}</span><span data-lang="ja">{t.hero.primary.ja}</span>
            <span class="arr">→</span>
          </a>
          <a class="btn alt" href={repo} target="_blank" rel="noopener">
            <span data-lang="en">{t.hero.secondary.en}</span><span data-lang="zh">{t.hero.secondary.zh}</span><span data-lang="ja">{t.hero.secondary.ja}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Hero 下方:仿真终端窗口(横向全宽,左提示卡 + 右终端区) -->
    <div class="wrap">
      <div class="hero-art fade-in delay-1" aria-hidden="true">
        <div class="app-window mock-terminal hero-window">
          <div class="app-titlebar">
            <div class="tb-icon" title="sidebar">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg>
            </div>
            <div class="app-tabs">
              <div class="app-tab active"><span>~ - fish</span></div>
              <div class="app-tab add">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" style="width:9px;height:9px;opacity:.6"><path d="M3 4l3 4 3-4"/></svg>
              </div>
            </div>
            <div class="app-controls">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 9l5-5 5 5M8 4v9"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2.5" y="3" width="11" height="8" rx="1"/><path d="M2.5 7h11"/></svg></div>
              <button class="tb-icon tb-theme" type="button" data-theme-toggle title="Toggle theme" aria-label="Toggle color theme">
                <svg class="tb-theme-svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <g class="tb-sun">
                    <circle cx="8" cy="8" r="3"/>
                    <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.2 3.2l1.4 1.4M11.4 11.4l1.4 1.4M3.2 12.8l1.4-1.4M11.4 4.6l1.4-1.4"/>
                  </g>
                  <path class="tb-moon" d="M14 9.5A6 6 0 1 1 6.5 2a5 5 0 0 0 7.5 7.5z"/>
                </svg>
              </button>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 8h10"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="10" height="10" rx="1"/></svg></div>
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 4l8 8M12 4l-8 8"/></svg></div>
            </div>
          </div>
          <div class="app-body">
            <!-- 左侧:快捷键提示卡 + 状态栏 -->
            <div class="hero-side">
              <div class="hero-hint">
                <div class="hh-title">
                  <svg class="ico" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11l4-4 4 4M3 7l4-4 4 4"/></svg>
                  <span data-lang="en">New terminal session</span><span data-lang="zh">新建终端会话</span><span data-lang="ja">新しいセッション</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">ctrl</span><span class="kbd">shift</span><span class="kbd">↩</span></span>
                  <span data-lang="en">New Agent chat</span><span data-lang="zh">新 Agent 对话</span><span data-lang="ja">新しい Agent 会話</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">↑</span></span>
                  <span data-lang="en">History</span><span data-lang="zh">历史记录</span><span data-lang="ja">履歴</span>
                </div>
                <div class="hh-row">
                  <span class="kbds"><span class="kbd">⌘</span><span class="kbd">K</span></span>
                  <span data-lang="en">Command palette</span><span data-lang="zh">命令面板</span><span data-lang="ja">コマンドパレット</span>
                </div>
              </div>
              <div class="hero-status">
                <span class="ok">anthropic / claude-4-7</span>
                <span>local · no telemetry</span>
              </div>
            </div>

            <!-- 右侧:终端输出 + 可执行输入 -->
            <div class="hero-main">
              <div class="term-stage"></div>
              <div class="term-input live">
                <div class="ti-fakeshell">
                  <span class="ps1">~ $</span>
                  <input
                    id="hero-shell-input"
                    type="text"
                    autocomplete="off"
                    spellcheck="false"
                    data-lang="en"
                    placeholder="Try: help, ls, agent fix the linker error, provider list"
                  />
                  <input
                    type="text"
                    autocomplete="off"
                    spellcheck="false"
                    data-lang="zh"
                    placeholder="试试:help、ls、agent 修复链接错误、provider list"
                  />
                  <input
                    type="text"
                    autocomplete="off"
                    spellcheck="false"
                    data-lang="ja"
                    placeholder="例:help、ls、agent リンカーエラーを修正、provider list"
                  />
                </div>
                <div class="ti-help">
                  <span data-lang="en">Type <code>help</code> for commands · <code>↑</code>/<code>↓</code> history · <code>clear</code> reset</span>
                  <span data-lang="zh"><code>help</code> 查看命令 · <code>↑</code>/<code>↓</code> 历史 · <code>clear</code> 清屏</span>
                  <span data-lang="ja"><code>help</code> で一覧 · <code>↑</code>/<code>↓</code> 履歴 · <code>clear</code> でクリア</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== LOGOS / PROTOCOLS ============== -->
  <div class="logos fade-in">
    <p class="logos-title">
      <span data-lang="en">{t.logos.title.en}</span><span data-lang="zh">{t.logos.title.zh}</span><span data-lang="ja">{t.logos.title.ja}</span>
    </p>
    <div class="logos-track">
      {protocols.map((p) => <span class="item">{p}</span>)}
    </div>
  </div>

  <!-- ============== FEAT 1: 终端 ============== -->
  <section class="section" id="how">
    <div class="wrap">
      <article class="feat-card fade-in">
        <div class="feat-text">
          <div class="feat-eyebrow">
            <span data-lang="en">{t.feat1.eyebrow.en}</span><span data-lang="zh">{t.feat1.eyebrow.zh}</span><span data-lang="ja">{t.feat1.eyebrow.ja}</span>
          </div>
          <h3 data-lang="en">{t.feat1.h.en}</h3>
          <h3 data-lang="zh">{t.feat1.h.zh}</h3>
          <h3 data-lang="ja">{t.feat1.h.ja}</h3>
          <p data-lang="en">{t.feat1.p.en}</p>
          <p data-lang="zh">{t.feat1.p.zh}</p>
          <p data-lang="ja">{t.feat1.p.ja}</p>
          <a class="more" href="/docs/quickstart">
            <span data-lang="en">{t.feat1.more.en}</span><span data-lang="zh">{t.feat1.more.zh}</span><span data-lang="ja">{t.feat1.more.ja}</span>
          </a>
        </div>
        <div class="feat-vis">
          <div class="app-window mock-terminal" style="min-height:340px">
            <div class="app-titlebar">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg></div>
              <div class="app-tabs">
                <div class="app-tab active">~/zap - fish</div>
                <div class="app-tab add">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                </div>
              </div>
            </div>
            <div class="app-body">
              <div class="term-stage">
                <div class="typing-line"><span class="p">$</span> cargo build --release</div>
                <div class="typing-line dim">   Compiling zap v0.1.0</div>
                <div class="typing-line dim">   Compiling warp_terminal v0.1.0</div>
                <div class="typing-line"><span class="ok">✓</span> <span class="dim">Finished in 12.4s</span></div>
              </div>
              <div class="term-input" style="margin-top:auto">
                <span class="ti-chip">block · cwd · env · exit</span>
                <div class="ti-prompt" data-lang="en">▌ Why did the linker fail on this target?</div>
                <div class="ti-prompt" data-lang="zh">▌ 这个 target 链接为什么失败?</div>
                <div class="ti-prompt" data-lang="ja">▌ なぜこのターゲットでリンカーが失敗したのか?</div>
                <div class="ti-meta">
                  <span style="font-family: 'JetBrains Mono', monospace; color: var(--accent)">/agent</span>
                  <span data-lang="en">Anthropic · claude-opus-4-7</span><span data-lang="zh">Anthropic · claude-opus-4-7</span><span data-lang="ja">Anthropic · claude-opus-4-7</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============== FEAT 2: 服务商(reverse 布局) ============== -->
  <section class="section" id="adapt">
    <div class="wrap">
      <article class="feat-card reverse fade-in">
        <div class="feat-text">
          <div class="feat-eyebrow">
            <span data-lang="en">{t.feat2.eyebrow.en}</span><span data-lang="zh">{t.feat2.eyebrow.zh}</span><span data-lang="ja">{t.feat2.eyebrow.ja}</span>
          </div>
          <h3 data-lang="en">{t.feat2.h.en}</h3>
          <h3 data-lang="zh">{t.feat2.h.zh}</h3>
          <h3 data-lang="ja">{t.feat2.h.ja}</h3>
          <p data-lang="en">{t.feat2.p.en}</p>
          <p data-lang="zh">{t.feat2.p.zh}</p>
          <p data-lang="ja">{t.feat2.p.ja}</p>
          <a class="more" href={repo} target="_blank" rel="noopener">
            <span data-lang="en">{t.feat2.more.en}</span><span data-lang="zh">{t.feat2.more.zh}</span><span data-lang="ja">{t.feat2.more.ja}</span>
          </a>
        </div>
        <div class="feat-vis">
          <div class="app-window mock-settings">
            <div class="app-titlebar">
              <div class="tb-icon"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3" width="12" height="10" rx="1.5"/><path d="M6 3v10"/></svg></div>
              <div class="app-tabs">
                <div class="app-tab">~ - fish</div>
                <div class="app-tab active">
                  <span data-lang="en">Settings</span><span data-lang="zh">设置</span><span data-lang="ja">設定</span>
                </div>
                <div class="app-tab add">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 3v10M3 8h10"/></svg>
                </div>
              </div>
            </div>
            <div class="app-body">
              <!-- 左 sidebar -->
              <div class="set-sidebar">
                <div class="ss-search">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="7" cy="7" r="4.5"/><path d="M14 14l-3.5-3.5"/></svg>
                  <span data-lang="en">Search</span><span data-lang="zh">搜索</span><span data-lang="ja">検索</span>
                </div>
                <div class="ss-group">
                  <span>Agents</span><span class="chev">▾</span>
                </div>
                <a class="ss-item" data-lang="en">Zap agent</a><a class="ss-item" data-lang="zh">Zap 智能体</a><a class="ss-item" data-lang="ja">Zap エージェント</a>
                <a class="ss-item" data-lang="en">Config</a><a class="ss-item" data-lang="zh">配置</a><a class="ss-item" data-lang="ja">設定</a>
                <a class="ss-item active" data-lang="en">Providers</a><a class="ss-item active" data-lang="zh">提供商</a><a class="ss-item active" data-lang="ja">プロバイダー</a>
                <a class="ss-item" data-lang="en">MCP servers</a><a class="ss-item" data-lang="zh">MCP 服务器</a><a class="ss-item" data-lang="ja">MCP サーバー</a>
                <a class="ss-item">Rules</a>
                <a class="ss-top muted" data-lang="en">Code</a><a class="ss-top muted" data-lang="zh">代码</a><a class="ss-top muted" data-lang="ja">コード</a>
                <a class="ss-top muted" data-lang="en">Appearance</a><a class="ss-top muted" data-lang="zh">外观</a><a class="ss-top muted" data-lang="ja">外観</a>
                <a class="ss-top muted" data-lang="en">Features</a><a class="ss-top muted" data-lang="zh">功能</a><a class="ss-top muted" data-lang="ja">機能</a>
              </div>

              <!-- 右内容 -->
              <div class="set-content">
                <div class="sc-head">
                  <h4 class="sc-h3">
                    <span data-lang="en">Agent providers</span><span data-lang="zh">Agent 提供商</span><span data-lang="ja">Agent プロバイダー</span>
                  </h4>
                  <button class="sc-add" type="button">+ <span data-lang="en">Add</span><span data-lang="zh">添加提供商</span><span data-lang="ja">追加</span></button>
                </div>
                <p class="sc-desc">
                  <span data-lang="en">Configure any OpenAI-compatible / Anthropic / Gemini / Ollama / DeepSeek endpoint. Keys are stored in the OS keychain.</span>
